{
  "name": "@mortise/session-mcp-server",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "description": "MCP server that provides session-scoped tools (config_validate, skill_validate, etc.) to the agent via stdio transport",
  "type": "commonjs",
  "main": "dist/index.js",
  "bin": {
    "session-mcp-server": "./dist/index.js"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir=dist --target=node --format=cjs --define process.env.MORTISE_UI_VALIDATION_BUILD=\\\"0\\\" --define process.env.MORTISE_UI_TEST_HOST=\\\"0\\\" --minify-syntax",
    "dev": "bun run src/index.ts"
  },
  "dependencies": {
    "@mortise/session-tools-core": "workspace:*",
    "@mortise/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0"
  }
}
