{
  "name": "@mortise/server-core",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "description": "Reusable headless server infrastructure for Mortise Agent",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./transport": "./src/transport/index.ts",
    "./transport/client": "./src/transport/client.ts",
    "./runtime": "./src/runtime/index.ts",
    "./handlers": "./src/handlers/index.ts",
    "./bootstrap": "./src/bootstrap/index.ts",
    "./model-fetchers": "./src/model-fetchers/index.ts",
    "./domain": "./src/domain/index.ts",
    "./projection": "./src/projection/index.ts",
    "./services": "./src/services/index.ts",
    "./capabilities": "./src/capabilities/index.ts",
    "./handlers/rpc": "./src/handlers/rpc/index.ts",
    "./handlers/rpc/*": "./src/handlers/rpc/*.ts",
    "./sessions": "./src/sessions/index.ts",
    "./webui": "./src/webui/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mortise/core": "workspace:*",
    "@mortise/shared": "workspace:*",
    "chokidar": "^3.6.0",
    "jose": "^6.0.0",
    "markitdown-js": "^0.0.14",
    "ws": "^8.19.0",
    "sharp": "0.34.5"
  },
  "devDependencies": {
    "typescript": "^5.8.2",
    "@types/node": "^22.0.0"
  }
}
