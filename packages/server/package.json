{
  "name": "@mortise/server",
  "version": "0.1.0",
  "description": "Standalone headless Mortise Agent server (Bun runtime)",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "mortise-server": "src/index.ts"
  },
  "files": [
    "src/"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "author": {
    "name": "Mortise Contributors"
  },
  "license": "Apache-2.0",
  "scripts": {
    "start": "bun run src/index.ts",
    "generate-token": "bun run src/index.ts --generate-token",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mortise/core": "workspace:*",
    "@mortise/messaging-gateway": "workspace:*",
    "@mortise/server-core": "workspace:*",
    "@mortise/shared": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.8.2",
    "@types/node": "^22.0.0",
    "ws": "^8.16.0"
  }
}
