{
	"name": "@mortise/pi-coding-agent",
	"version": "0.1.0",
	"description": "Coding agent CLI with read, bash, edit, write tools and session management",
	"type": "module",
	"piConfig": {
		"configDir": ".pi",
		"updateChannel": "published"
	},
	"bin": {
		"pi": "dist/cli.bundle.js"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./host-facade": {
			"types": "./dist/core/host-facade.d.ts",
			"import": "./dist/core/host-facade.js",
			"require": "./dist/core/host-facade.cjs"
		},
		"./rpc": {
			"types": "./dist/modes/rpc/public.d.ts",
			"import": "./dist/modes/rpc/public.js",
			"require": "./dist/modes/rpc/rpc-client.cjs"
		},
		"./hooks": {
			"types": "./dist/core/hooks/index.d.ts",
			"import": "./dist/core/hooks/index.js"
		}
	},
	"files": [
		"dist",
		"docs",
		"examples",
		"sidecar/bin",
		"CHANGELOG.md",
		"npm-shrinkwrap.json"
	],
	"scripts": {
		"clean": "shx rm -rf dist sidecar/bin",
		"build:sidecar": "node ./scripts/build-sidecar.mjs",
		"build:bundle": "node ../../scripts/build-coding-agent-bundle.mjs",
		"build:host-facade-cjs": "node ../../scripts/build-host-facade-cjs.mjs",
		"build": "npm run build:sidecar && tsgo -p tsconfig.build.json && npm run build:host-facade-cjs && npm run build:bundle && shx chmod +x dist/cli.js dist/cli.bundle.js && npm run copy-assets",
		"build:workspace": "tsgo -p tsconfig.build.json && npm run build:host-facade-cjs && npm run build:bundle && shx chmod +x dist/cli.js dist/cli.bundle.js && npm run copy-assets",
		"build:workspace:binary": "bun build --compile ./dist/bun/cli.js ./src/utils/image-resize-worker.ts --outfile dist/pi && npm run copy-binary-assets",
		"build:binary": "npm --prefix ../tui run build && npm --prefix ../ai run build && npm --prefix ../agent run build && npm run build && bun build --compile ./dist/bun/cli.js ./src/utils/image-resize-worker.ts --outfile dist/pi && npm run copy-binary-assets",
		"copy-assets": "node ./scripts/copy-assets.mjs",
		"copy-binary-assets": "node ./scripts/copy-assets.mjs --binary",
		"test": "vitest --run",
		"shrinkwrap": "node ../../scripts/generate-coding-agent-shrinkwrap.mjs",
		"prepublishOnly": "npm run clean && npm run build && npm run shrinkwrap"
	},
	"dependencies": {
		"@mortise/pi-agent-core": "0.1.0",
		"@mortise/pi-ai": "0.1.0",
		"@mortise/pi-tui": "0.1.0",
		"@mozilla/readability": "0.6.0",
		"@silvia-odwyer/photon-node": "0.3.4",
		"chalk": "5.6.2",
		"cross-spawn": "7.0.6",
		"diff": "8.0.4",
		"glob": "13.0.6",
		"highlight.js": "10.7.3",
		"hosted-git-info": "9.0.3",
		"ignore": "7.0.5",
		"jiti": "2.7.0",
		"jsdom": "27.3.0",
		"marked": "15.0.12",
		"minimatch": "10.2.5",
		"proper-lockfile": "4.1.2",
		"semver": "7.7.3",
		"typebox": "1.1.38",
		"undici": "8.5.0",
		"yaml": "2.9.0"
	},
	"overrides": {
		"rimraf": "6.1.2",
		"gaxios": {
			"rimraf": "6.1.2"
		}
	},
	"optionalDependencies": {
		"@mariozechner/clipboard": "0.3.9"
	},
	"devDependencies": {
		"@types/cross-spawn": "6.0.6",
		"@types/diff": "7.0.2",
		"@types/hosted-git-info": "3.0.5",
		"@types/jsdom": "28.0.3",
		"@types/ms": "2.1.0",
		"@types/node": "24.12.4",
		"@types/proper-lockfile": "4.1.4",
		"@types/semver": "7.7.1",
		"shx": "0.4.0",
		"typescript": "5.9.3",
		"vitest": "3.2.4"
	},
	"keywords": [
		"coding-agent",
		"ai",
		"llm",
		"cli",
		"tui",
		"agent"
	],
	"author": "Mario Zechner",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/hrhgit/mortise.git",
		"directory": "pi/packages/coding-agent"
	},
	"engines": {
		"node": ">=22.19.0"
	}
}
